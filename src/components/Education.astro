---
import site from '../data/site.json';
import SectionHeading from './SectionHeading.astro';
---

<section id="education" class="mx-auto max-w-5xl scroll-mt-14 px-6 py-32">
  <SectionHeading index="03" label="education" title="Where I studied" />
  <div class="grid gap-5 sm:grid-cols-2">
    {
      site.education.map((edu, i) => (
        <div class="card rounded-2xl p-7" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
          <div class="flex items-start justify-between gap-4">
            <h3 class="text-lg font-medium text-ink">{edu.school}</h3>
            <span
              class="shrink-0 whitespace-nowrap rounded-full border border-accent/30 bg-accent/10 px-3 py-1 font-mono text-sm font-medium text-accent"
            >
              GPA {edu.gpa}
            </span>
          </div>
          <p class="mt-1 text-sm text-muted">{edu.degree}</p>
          <p class="mt-1 font-mono text-xs text-muted">{edu.dates}</p>
          <ul class="mt-5 space-y-1.5 text-sm text-muted">
            {edu.notes.map((note) => (
              <li class="flex gap-2">
                <span class="text-accent">·</span>
                {note}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
  <div class="mt-16">
    <h3 class="font-mono text-xs uppercase tracking-[0.2em] text-muted" data-reveal>
      research & honors
    </h3>
    <div class="mt-6 grid gap-5 sm:grid-cols-2">
      {
        site.research.map((item, i) => (
          <div class="card rounded-2xl p-7" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
            {item.tag && (
              <p class="font-mono text-xs uppercase tracking-[0.15em] text-accent">{item.tag}</p>
            )}
            <p class="mt-3 text-lg font-medium leading-snug text-ink">{item.title}</p>
            <p class="mt-3 text-sm text-muted">{item.detail}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
