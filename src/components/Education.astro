---
import site from '../data/site.json';
import SectionHeading from './SectionHeading.astro';
---

<section id="education" class="mx-auto max-w-5xl scroll-mt-14 px-6 py-32">
  <SectionHeading index="03" label="education" title="Where I studied" />
  <div class="grid gap-5 sm:grid-cols-2">
    {
      site.education.map((edu, i) => (
        <div class="glass rounded-2xl p-7" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
          <div class="flex items-start justify-between gap-4">
            <h3 class="text-lg font-medium text-ink">{edu.school}</h3>
            <span class="whitespace-nowrap font-mono text-xs text-accent">{edu.gpa}</span>
          </div>
          <p class="mt-1 text-sm text-muted">{edu.degree}</p>
          <p class="mt-1 font-mono text-xs text-muted">{edu.dates}</p>
          <ul class="mt-5 space-y-1.5 text-sm text-muted">
            {edu.notes.map((note) => (
              <li class="flex gap-2">
                <span class="text-accent">·</span>
                {note}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
  <div class="mt-12" data-reveal>
    <h3 class="font-mono text-xs uppercase tracking-[0.2em] text-muted">research & honors</h3>
    <ul class="mt-5 space-y-4">
      {
        site.research.map((item) => (
          <li class="max-w-2xl">
            <p class="text-sm font-medium text-ink">{item.title}</p>
            <p class="mt-0.5 text-sm text-muted">{item.detail}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
