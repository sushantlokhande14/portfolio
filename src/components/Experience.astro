---
import { getCollection, render } from 'astro:content';
import SectionHeading from './SectionHeading.astro';

const entries = (await getCollection('experience')).sort((a, b) => a.data.order - b.data.order);
const rendered = await Promise.all(
  entries.map(async (entry) => ({ entry, Content: (await render(entry)).Content }))
);
---

<section id="experience" class="mx-auto max-w-5xl scroll-mt-14 px-6 py-28">
  <SectionHeading index="02" label="experience" title="Where I've worked" />
  <ol class="relative ml-1 space-y-12 border-l border-line pl-8">
    {
      rendered.map(({ entry, Content }) => (
        <li class="relative">
          <span class="absolute -left-[37px] top-1.5 size-2.5 rounded-full bg-accent" />
          <p class="font-mono text-xs text-muted">
            {entry.data.start} — {entry.data.end}
          </p>
          <h3 class="mt-2 text-lg font-medium text-ink">
            {entry.data.role} <span class="text-muted">· {entry.data.org}</span>
          </h3>
          <div class="mt-2 max-w-2xl text-sm leading-relaxed text-muted">
            <Content />
          </div>
          {entry.data.tech.length > 0 && (
            <ul class="mt-3 flex flex-wrap gap-x-4 gap-y-1 font-mono text-xs text-muted">
              {entry.data.tech.map((t) => (
                <li>{t}</li>
              ))}
            </ul>
          )}
        </li>
      ))
    }
  </ol>
</section>
