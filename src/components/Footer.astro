---
import site from '../data/site.json';

const year = new Date().getFullYear();
---

<footer id="contact" class="border-t border-line">
  <div class="mx-auto max-w-5xl px-6 py-32">
    <div data-reveal>
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted">
        <span class="text-accent">06</span> — contact
      </p>
      <h2 class="text-gradient mt-4 text-4xl font-semibold tracking-tight sm:text-6xl">
        Let's build something.
      </h2>
      <a
        href={`mailto:${site.email}`}
        class="mt-8 inline-block text-xl text-accent underline-offset-4 hover:underline"
      >
        {site.email}
      </a>
      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a
          href={site.resume}
          class="btn-primary rounded-full px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-85"
        >
          résumé ↓
        </a>
        <a
          href={site.github}
          class="rounded-full border border-line px-5 py-2.5 font-mono text-sm text-muted transition-colors hover:border-accent hover:text-accent"
        >
          github ↗
        </a>
        <a
          href={site.linkedin}
          class="rounded-full border border-line px-5 py-2.5 font-mono text-sm text-muted transition-colors hover:border-accent hover:text-accent"
        >
          linkedin ↗
        </a>
      </div>
    </div>
    <div
      class="mt-20 flex flex-col gap-4 border-t border-line pt-8 font-mono text-xs text-muted sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {site.name}</p>
      <a href={site.repo} class="transition-colors hover:text-ink">view source ↗</a>
    </div>
  </div>
</footer>
