---
import site from '../data/site.json';

const year = new Date().getFullYear();
---

<footer id="contact" class="border-t border-line">
  <div class="mx-auto max-w-5xl px-6 py-28">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted">
      <span class="text-accent">05</span> — contact
    </p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
      Let's build something.
    </h2>
    <a
      href={`mailto:${site.email}`}
      class="mt-6 inline-block text-lg text-accent underline-offset-4 hover:underline"
    >
      {site.email}
    </a>
    <div class="mt-16 flex flex-col gap-4 border-t border-line pt-8 font-mono text-xs text-muted sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {site.name}</p>
      <div class="flex gap-6">
        <a href={site.github} class="transition-colors hover:text-ink">github</a>
        <a href={site.linkedin} class="transition-colors hover:text-ink">linkedin</a>
        <a href={site.repo} class="transition-colors hover:text-ink">view source ↗</a>
      </div>
    </div>
  </div>
</footer>
