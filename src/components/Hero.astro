---
import site from '../data/site.json';
---

<section class="relative flex min-h-screen flex-col justify-center overflow-hidden pt-14">
  <div class="mx-auto w-full max-w-5xl px-6">
    <h1
      class="text-gradient reveal max-w-4xl text-6xl font-semibold leading-[1.02] tracking-tight sm:text-8xl"
    >
      {site.name}
    </h1>
    <p class="reveal mt-8 max-w-2xl text-xl leading-relaxed text-muted" style="--delay: 120ms">
      {site.tagline}
    </p>
    <p class="reveal mt-5 max-w-xl text-base leading-relaxed text-ink/80" style="--delay: 200ms">
      {site.cta}
    </p>
    <div class="reveal mt-10 flex flex-wrap items-center gap-3" style="--delay: 280ms">
      <a
        href="/#projects"
        class="btn-primary rounded-full px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-85"
      >
        View my work
      </a>
      <a
        href={site.resume}
        class="rounded-full border border-line px-5 py-2.5 font-mono text-sm text-muted transition-colors hover:border-accent hover:text-accent"
      >
        résumé ↓
      </a>
      <a
        href={site.github}
        class="rounded-full border border-line px-5 py-2.5 font-mono text-sm text-muted transition-colors hover:border-accent hover:text-accent"
      >
        github ↗
      </a>
      <a
        href={site.linkedin}
        class="rounded-full border border-line px-5 py-2.5 font-mono text-sm text-muted transition-colors hover:border-accent hover:text-accent"
      >
        linkedin ↗
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2" aria-hidden="true">
    <span class="scroll-line"></span>
  </div>
</section>
