---
import site from '../data/site.json';
import SectionHeading from './SectionHeading.astro';

// education above the rail, oldest -> newest left to right
const education = [...site.education].reverse();
// work below the rail, oldest -> newest left to right
const work = site.timeline.filter((t) => t.type === 'work').reverse();
---

<section id="experience" class="mx-auto max-w-5xl scroll-mt-14 px-6 py-32">
  <SectionHeading index="02" label="journey" title="Where I've been" />

  <!-- education, above the line -->
  <div class="grid gap-5 sm:grid-cols-2 sm:gap-x-8 sm:gap-y-0">
    {
      education.map((edu, i) => (
        <div class="flex flex-col items-center">
          <article
            class="card flex w-full flex-1 flex-col overflow-hidden rounded-2xl"
            data-reveal
            style={`--reveal-delay: ${i * 80}ms`}
          >
            {edu.image && (
              <img
                src={edu.image}
                alt={edu.school}
                loading="lazy"
                onerror="this.style.display='none'"
                class="h-44 w-full object-cover"
              />
            )}
            <div class="flex flex-1 flex-col p-7">
              <div class="flex items-start justify-between gap-4">
                <h3 class="text-lg font-medium text-ink">{edu.school}</h3>
                <span class="shrink-0 whitespace-nowrap rounded-full border border-accent/30 bg-accent/10 px-3 py-1 font-mono text-sm font-medium text-accent">
                  GPA {edu.gpa}
                </span>
              </div>
              <p class="mt-1 text-sm text-muted">{edu.degree}</p>
              <p class="mt-1 font-mono text-xs text-muted">{edu.dates}</p>
              <ul class="mt-5 space-y-1.5 text-sm text-muted">
                {edu.notes.map((note) => (
                  <li class="flex gap-2">
                    <span class="text-accent">·</span>
                    {note}
                  </li>
                ))}
              </ul>
            </div>
          </article>
          <div class="hidden h-8 w-px bg-line sm:block" aria-hidden="true" />
          <div class="relative z-10 hidden size-2.5 rounded-full bg-accent sm:block" aria-hidden="true" />
        </div>
      ))
    }
  </div>

  <!-- the rail -->
  <div class="-mt-[6px] hidden h-px bg-line sm:block" aria-hidden="true"></div>

  <!-- work, below the line -->
  <div class="mt-5 grid gap-5 sm:mt-0 sm:grid-cols-3 sm:gap-x-8 sm:gap-y-0">
    {
      work.map((job, i) => (
        <div class="flex flex-col items-center">
          <div class="relative z-10 -mt-[6px] hidden size-2.5 rounded-full bg-accent sm:block" aria-hidden="true" />
          <div class="hidden h-8 w-px bg-line sm:block" aria-hidden="true" />
          <article
            class="card flex w-full flex-1 items-center gap-4 rounded-2xl p-6"
            data-reveal
            style={`--reveal-delay: ${i * 80}ms`}
          >
            <img
              src={job.logo}
              alt={job.org}
              width="48"
              height="48"
              loading="lazy"
              class="size-12 shrink-0 rounded-xl border border-line object-cover"
            />
            <div class="min-w-0">
              <h3 class="text-base font-medium leading-snug text-ink">{job.title}</h3>
              <p class="mt-0.5 truncate text-sm text-muted">{job.org}</p>
              <p class="mt-1 font-mono text-xs text-muted">
                {job.start} — {job.end}
              </p>
            </div>
          </article>
        </div>
      ))
    }
  </div>
</section>
