---
import site from '../data/site.json';
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { label: 'projects', href: '/#projects' },
  { label: 'experience', href: '/#experience' },
  { label: 'about', href: '/#about' },
];
---

<header id="site-nav" class="fixed inset-x-0 top-0 z-50">
  <nav class="mx-auto flex h-14 max-w-5xl items-center justify-between px-6">
    <a href="/" class="font-mono text-sm text-ink transition-colors hover:text-accent">
      sushant<span class="text-accent">.</span>
    </a>
    <div class="flex items-center gap-5">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="hidden font-mono text-xs text-muted transition-colors hover:text-ink sm:block"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={site.resume}
        class="rounded-full border border-line px-3.5 py-1.5 font-mono text-xs text-ink transition-colors hover:border-accent hover:text-accent"
      >
        résumé
      </a>
      <ThemeToggle />
    </div>
  </nav>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const onScroll = () => nav?.classList.toggle('nav-scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
