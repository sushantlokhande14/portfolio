---
import site from '../data/site.json';

const links = [
  { label: 'projects', href: '/#projects' },
  { label: 'experience', href: '/#experience' },
  { label: 'about', href: '/#about' },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-line bg-base/80 backdrop-blur-md">
  <nav class="mx-auto flex h-14 max-w-5xl items-center justify-between px-6">
    <a href="/" class="font-mono text-sm text-ink transition-colors hover:text-accent">
      sushant<span class="text-accent">.</span>
    </a>
    <div class="flex items-center gap-6">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="hidden font-mono text-xs text-muted transition-colors hover:text-ink sm:block"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={site.resume}
        class="rounded-md border border-line px-3 py-1.5 font-mono text-xs text-ink transition-colors hover:border-accent hover:text-accent"
      >
        résumé
      </a>
    </div>
  </nav>
</header>
