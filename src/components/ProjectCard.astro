---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<a
  href={`/projects/${project.id}/`}
  class="card group flex h-full flex-col justify-between rounded-2xl p-7 transition-all duration-300 hover:-translate-y-1 hover:border-ink/20"
>
  <div>
    <div class="flex items-start justify-between">
      <h3 class="text-lg font-medium text-ink">{project.data.title}</h3>
      <span
        class="text-muted transition-all duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-accent"
      >
        ↗
      </span>
    </div>
    <p class="mt-3 text-sm leading-relaxed text-muted">{project.data.summary}</p>
  </div>
  <ul class="mt-7 flex flex-wrap gap-x-4 gap-y-1 font-mono text-xs text-muted">
    {project.data.tech.map((t) => <li>{t}</li>)}
  </ul>
</a>
