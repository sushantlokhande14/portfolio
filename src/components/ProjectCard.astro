---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<a
  href={`/projects/${project.id}/`}
  class="card group flex h-full flex-col overflow-hidden rounded-2xl transition-all duration-300 hover:-translate-y-1 hover:border-ink/20"
>
  {project.data.cover && (
    <img src={project.data.cover} alt="" loading="lazy" class="aspect-[16/8] w-full object-cover" />
  )}
  <div class="flex flex-1 flex-col justify-between p-6">
    <div>
      <div class="flex items-start justify-between">
        <div>
          <h3 class="text-lg font-semibold tracking-tight text-ink">{project.data.title}</h3>
          {project.data.subtitle && (
            <p class="mt-1 text-sm font-medium text-accent">{project.data.subtitle}</p>
          )}
        </div>
        <span
          class="text-muted transition-all duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-accent"
        >
          ↗
        </span>
      </div>
      <p class="mt-3 text-sm leading-relaxed text-muted">{project.data.summary}</p>
    </div>
    <ul class="mt-6 flex flex-wrap gap-x-4 gap-y-1 font-mono text-xs text-muted">
      {project.data.tech.map((t) => <li>{t}</li>)}
    </ul>
  </div>
</a>
