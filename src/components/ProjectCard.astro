---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<a
  href={`/projects/${project.id}/`}
  class="group flex flex-col justify-between rounded-xl border border-line bg-surface p-6 transition-all duration-200 hover:-translate-y-1 hover:border-white/20"
>
  <div>
    <div class="flex items-start justify-between">
      <h3 class="text-lg font-medium text-ink">{project.data.title}</h3>
      <span class="text-muted transition-colors group-hover:text-accent">↗</span>
    </div>
    <p class="mt-3 text-sm leading-relaxed text-muted">{project.data.summary}</p>
  </div>
  <ul class="mt-6 flex flex-wrap gap-x-4 gap-y-1 font-mono text-xs text-muted">
    {project.data.tech.map((t) => <li>{t}</li>)}
  </ul>
</a>
