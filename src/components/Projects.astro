---
import { getCollection } from 'astro:content';
import SectionHeading from './SectionHeading.astro';
import ProjectCard from './ProjectCard.astro';

const projects = (await getCollection('projects', ({ data }) => data.featured)).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="projects" class="mx-auto max-w-5xl scroll-mt-14 px-6 py-32">
  <SectionHeading index="01" label="projects" title="Things I've built" />
  <div class="grid gap-5 sm:grid-cols-2">
    {
      projects.map((project, i) => (
        <div data-reveal style={`--reveal-delay: ${i * 80}ms`}>
          <ProjectCard project={project} />
        </div>
      ))
    }
  </div>
  <div class="mt-10" data-reveal>
    <a
      href="/projects/"
      class="font-mono text-sm text-muted transition-colors hover:text-accent"
    >
      all projects →
    </a>
  </div>
</section>
