---
import { getCollection } from 'astro:content';
import SectionHeading from './SectionHeading.astro';

const projects = (await getCollection('projects', ({ data }) => data.featured)).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="projects" class="scroll-mt-14 overflow-x-clip py-32">
  <div class="mx-auto max-w-5xl px-6">
    <SectionHeading index="01" label="projects" title="Things I've built" />
  </div>

  <div class="pc relative mx-auto max-w-5xl px-6" data-carousel data-reveal>
    <button class="pc-arrow prev" type="button" aria-label="Previous project">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="size-4"
      >
        <path d="m15 18-6-6 6-6"></path>
      </svg>
    </button>

    <div class="pc-stage">
      {
        projects.map((p, i) => (
          <a href={`/projects/${p.id}/`} class="pc-slide" data-index={i}>
            <article class="pc-card card">
              <div>
                <div class="flex items-start justify-between gap-3">
                  <h3 class="text-lg font-medium text-ink">{p.data.title}</h3>
                  <span class="pc-tick text-muted">↗</span>
                </div>
                <p class="mt-3 line-clamp-3 text-sm leading-relaxed text-muted">{p.data.summary}</p>
              </div>
              <div>
                <ul class="flex flex-wrap gap-x-4 gap-y-1 font-mono text-xs text-muted">
                  {p.data.tech.slice(0, 5).map((t) => <li>{t}</li>)}
                </ul>
                <p class="pc-hint mt-4 font-mono text-xs text-accent">view case study →</p>
              </div>
            </article>
          </a>
        ))
      }
    </div>

    <button class="pc-arrow next" type="button" aria-label="Next project">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="size-4"
      >
        <path d="m9 18 6-6-6-6"></path>
      </svg>
    </button>
  </div>

  <div class="pc-dots mt-12" data-dots>
    {
      projects.map((_, i) => (
        <button class="pc-dot" type="button" data-dot={i} aria-label={`Go to project ${i + 1}`} />
      ))
    }
  </div>

  <div class="mt-12 text-center" data-reveal>
    <a href="/projects/" class="font-mono text-sm text-muted transition-colors hover:text-accent">
      all projects →
    </a>
  </div>
</section>

<script>
  function initCarousel(root: HTMLElement) {
    const stage = root.querySelector<HTMLElement>('.pc-stage');
    const slides = Array.from(root.querySelectorAll<HTMLAnchorElement>('.pc-slide'));
    const prevBtn = root.querySelector<HTMLButtonElement>('.pc-arrow.prev');
    const nextBtn = root.querySelector<HTMLButtonElement>('.pc-arrow.next');
    const section = root.closest('section');
    const dots = section ? Array.from(section.querySelectorAll<HTMLButtonElement>('.pc-dot')) : [];
    const n = slides.length;
    if (!stage || !n) return;

    const VISIBLE = 2;
    let active = 0;
    let hovered = -1;
    let step = 300;

    function metrics() {
      const w = stage!.clientWidth || root.clientWidth;
      step = Math.max(150, Math.min(320, w * 0.34));
    }

    function layout() {
      slides.forEach((slide, i) => {
        let d = i - active;
        if (d > n / 2) d -= n;
        if (d < -n / 2) d += n;
        const ad = Math.abs(d);
        const sign = Math.sign(d);
        const hidden = ad > VISIBLE;

        // teleport (skip transition) when a card wraps to the opposite side,
        // so it never slides across the center
        const prevD = (slide as any)._d;
        if (prevD !== undefined && Math.abs(d - prevD) > n / 2) {
          slide.style.transition = 'none';
          requestAnimationFrame(() => {
            slide.style.transition = '';
          });
        }
        (slide as any)._d = d;

        let scale = Math.max(1 - ad * 0.13, 0.6);
        const tx = d * step;
        let tz = -ad * 80;
        const ry = -sign * Math.min(ad, 2) * 8;
        let ty = 0;
        let op = hidden ? 0 : Math.max(1 - ad * 0.34, 0.3);
        let z = 100 - ad;
        if (i === hovered && d !== 0 && !hidden) {
          scale += 0.06;
          op = Math.min(op + 0.3, 1);
          tz += 50;
          ty = -10;
          z = 130;
        }
        slide.style.transform = `translate(-50%, ${ty}px) translateX(${tx}px) translateZ(${tz}px) rotateY(${ry}deg) scale(${scale})`;
        slide.style.opacity = String(op);
        slide.style.zIndex = String(z);
        slide.style.pointerEvents = hidden ? 'none' : 'auto';
        slide.setAttribute('aria-hidden', hidden ? 'true' : 'false');
        slide.setAttribute('tabindex', d === 0 ? '0' : '-1');
        slide.classList.toggle('is-active', d === 0);
      });
      dots.forEach((dot, i) => dot.classList.toggle('is-on', i === active));
    }

    function go(to: number) {
      active = ((to % n) + n) % n;
      layout();
    }

    prevBtn?.addEventListener('click', () => go(active - 1));
    nextBtn?.addEventListener('click', () => go(active + 1));

    let dragMoved = false;
    let startX: number | null = null;
    let startY = 0;

    slides.forEach((slide, i) => {
      slide.addEventListener('click', (e) => {
        if (dragMoved || i !== active) {
          e.preventDefault();
          if (i !== active) go(i);
        }
      });
      slide.addEventListener('mouseenter', () => {
        hovered = i;
        layout();
      });
      slide.addEventListener('mouseleave', () => {
        hovered = -1;
        layout();
      });
    });

    dots.forEach((dot, i) => dot.addEventListener('click', () => go(i)));

    root.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        go(active - 1);
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        go(active + 1);
      }
    });

    stage.addEventListener('pointerdown', (e) => {
      startX = e.clientX;
      startY = e.clientY;
      dragMoved = false;
    });
    stage.addEventListener('pointermove', (e) => {
      if (startX !== null && Math.abs(e.clientX - startX) > 8) dragMoved = true;
    });
    stage.addEventListener('pointerup', (e) => {
      if (startX !== null) {
        const dx = e.clientX - startX;
        const dy = e.clientY - startY;
        // only act on a deliberate horizontal swipe
        if (dragMoved && Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy) * 1.5) {
          go(active + (dx < 0 ? 1 : -1));
        }
      }
      startX = null;
      setTimeout(() => {
        dragMoved = false;
      }, 0);
    });

    let rt: number;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = window.setTimeout(() => {
        metrics();
        layout();
      }, 120);
    });

    metrics();
    layout();
    requestAnimationFrame(() => root.classList.add('is-ready'));
  }

  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((el) => initCarousel(el));
</script>
