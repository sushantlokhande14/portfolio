---
interface Props {
  index: string;
  label: string;
  title: string;
}

const { index, label, title } = Astro.props;
---

<div class="mb-12">
  <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted">
    <span class="text-accent">{index}</span> — {label}
  </p>
  <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
    {title}
  </h2>
</div>
