---
interface Props {
  index: string;
  label: string;
  title: string;
}

const { index, label, title } = Astro.props;
---

<div class="mb-14" data-reveal>
  <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted">
    <span class="text-accent">{index}</span> — {label}
  </p>
  <h2 class="mt-4 text-4xl font-semibold tracking-tight text-ink sm:text-5xl">
    {title}<span class="text-accent">.</span>
  </h2>
</div>
