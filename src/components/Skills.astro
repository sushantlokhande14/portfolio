---
import site from '../data/site.json';
import SectionHeading from './SectionHeading.astro';
---

<section id="skills" class="mx-auto max-w-5xl scroll-mt-14 px-6 py-32">
  <SectionHeading index="04" label="skills" title="What I work with" />
  <div class="grid grid-cols-2 gap-5 md:grid-cols-4">
    {
      site.skills.map((group, i) => (
        <div class="card rounded-2xl p-6" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
          <h3 class="font-mono text-xs uppercase tracking-[0.2em] text-muted">{group.group}</h3>
          <ul class="mt-4 space-y-2 text-sm text-ink/80">
            {group.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
